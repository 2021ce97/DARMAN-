rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────────────────

    /// Check if request is from an authenticated user
    function isAuth() {
      return request.auth != null;
    }

    /// Check if the requesting user owns this document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    /// Fetch the role of the requesting user from /users/{uid}
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    /// Only admins can call this
    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    /// Only doctors can call this
    function isDoctor() {
      return isAuth() && getRole() == 'doctor';
    }

    /// Only patients can call this
    function isPatient() {
      return isAuth() && getRole() == 'patient';
    }

    /// User is not banned
    function isNotBanned() {
      return !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false);
    }

    /// Check if a user document's owner matches auth
    function isUserDoc(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── /users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone authenticated can read their own profile; admins can read all
      allow read: if isUserDoc(uid) || isAdmin();

      // Users can create their own document on registration
      allow create: if isUserDoc(uid)
        && request.resource.data.role in ['patient', 'doctor']
        && request.resource.data.keys().hasAll(['email', 'name', 'role']);

      // Users can update their own profile EXCEPT role and isBanned fields
      allow update: if isUserDoc(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'isBanned'])
        || isAdmin(); // Admins can update any field (role, isBanned, etc.)

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ── /doctors ─────────────────────────────────────────────────────────────
    match /doctors/{doctorId} {
      // Any authenticated user can read doctor profiles (for listings)
      allow read: if isAuth();

      // Doctors can create their OWN profile (docId == uid OR userId field == uid)
      allow create: if isAuth()
        && (doctorId == request.auth.uid
            || request.resource.data.get('userId', '') == request.auth.uid);

      allow update: if isAuth()
        && (
          // Doctor updates their own profile (cannot self-verify)
          ((resource.data.get('userId', '') == request.auth.uid || doctorId == request.auth.uid)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['status', 'verifiedAt']))
          // Admin can update any field including status/verifiedAt
          || isAdmin()
        );

      allow delete: if isAdmin();
    }

    // ── /appointments ────────────────────────────────────────────────────────
    match /appointments/{apptId} {
      // Patients see their own; doctors see appointments booked with them; admins see all
      allow read: if isAuth() && isNotBanned() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );

      // Any non-banned authenticated user can create (book) an appointment
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.keys().hasAll([
            'doctorId', 'patientId', 'dateTime', 'status', 'type', 'amount'
           ]);

      // Patient can update status to 'cancelled' or update rescheduled dateTime;
      // Doctor can update status to 'approved'/'completed'/'cancelled';
      // Admin can update anything
      allow update: if isAuth() && isNotBanned() && (
        (resource.data.patientId == request.auth.uid
          && request.resource.data.status in ['cancelled', 'rescheduled'])
        || (resource.data.doctorId == request.auth.uid
          && request.resource.data.status in ['approved', 'completed', 'cancelled'])
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── /notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications; admins can read all
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Only backend (Cloud Functions / admin SDK) or admins should create notifications
      // For client-side creation, allow if userId matches current user
      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );

      // Users can mark their own notifications as read
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead']);

      // Users can delete their own; admins can delete any
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ── /prescriptions ────────────────────────────────────────────────────────
    match /prescriptions/{prescId} {
      // Patient sees their own; doctor who wrote it; admins
      allow read: if isAuth() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );

      // Only verified doctors can create prescriptions
      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid;

      // Only the writing doctor can update; admins can always update
      allow update: if isAuth() && (
        resource.data.doctorId == request.auth.uid || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── /health_records ───────────────────────────────────────────────────────
    match /health_records/{recordId} {
      // Patients own their records; doctors with an active appointment can read
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isDoctor() || isAdmin()
      );

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;

      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ── /reviews ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true; // public

      // Only patients who have had a completed appointment can write
      allow create: if isAuth() && isPatient()
        && request.resource.data.patientId == request.auth.uid;

      // Only the review author can update their review
      allow update: if isAuth()
        && resource.data.patientId == request.auth.uid;

      allow delete: if isAdmin();
    }

    // ── /chats / /messages ────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isAuth()
        && request.auth.uid in resource.data.participants;
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read: if isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      allow create: if isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        && request.resource.data.senderId == request.auth.uid;

      allow update, delete: if false; // messages are immutable
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
