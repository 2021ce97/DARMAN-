# Production environment variables (example)
# Copy this file to `.env` locally for testing, or add values in your
# Render / hosting provider secrets dashboard for production deployments.

# Server
PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# Firebase (recommended: use FIREBASE_SERVICE_ACCOUNT_PATH pointing to a service account file)
FIREBASE_PROJECT_ID=mediconnect-4b155
# Either set FIREBASE_SERVICE_ACCOUNT_PATH=/full/path/to/serviceAccount.json
# OR provide the following three values (the private key MUST include newlines escaped as \n when stored in env)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@mediconnect-4b155.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n

# JWT
JWT_SECRET=replace-with-a-secure-random-string
JWT_EXPIRES_IN=7d

# Redis (optional)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Postgres (analytics - optional)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=mediconnect_analytics
POSTGRES_USER=
POSTGRES_PASSWORD=

# External APIs (placeholders) - PLEASE UPDATE WITH PRODUCTION KEYS
GEMINI_API_KEY=your-production-gemini-key
AGORA_APP_ID=your-production-agora-app-id
AGORA_APP_CERTIFICATE=your-production-agora-app-certificate
HESABPAY_API_KEY=your-production-hesabpay-key
HESABPAY_MERCHANT_ID=your-production-hesabpay-merchant-id
HESABPAY_BASE_URL=https://api.hesabpay.af

# App integrity
FIREBASE_APP_CHECK_ENFORCED=true

# SMS / Third-party
SMS_API_KEY=
SMS_SENDER_ID=MediConnect

# Rate limiting
RATE_LIMIT_MAX=200
RATE_LIMIT_TIMEWINDOW=60000
