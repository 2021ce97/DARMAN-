rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isDoctor() {
      return role() == 'doctor';
    }

    function isPatient() {
      return role() == 'patient';
    }

    function isNotBanned() {
      return hasUserDoc() && userDoc().data.get('isBanned', false) != true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.role in ['patient', 'doctor']
        && request.resource.data.keys().hasAll(['email', 'role']);
      allow update: if (
        isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'isBanned', 'disabled'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow create: if isAuth()
        && isNotBanned()
        && (doctorId == request.auth.uid
          || request.resource.data.get('userId', '') == request.auth.uid
          || isAdmin());
      allow update: if isAdmin() || (
        isDoctor()
        && isNotBanned()
        && (resource.data.get('userId', '') == request.auth.uid || doctorId == request.auth.uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'verifiedAt', 'verifiedBy'])
      );
      allow delete: if isAdmin();

      match /availability/{dateId} {
        allow read: if true;
        allow write: if isAdmin() || (
          isDoctor()
          && get(/databases/$(database)/documents/doctors/$(doctorId)).data.get('userId', '') == request.auth.uid
        );
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isAuth() && isNotBanned() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.keys().hasAll(['doctorId', 'patientId', 'dateTime', 'status', 'type', 'amount']);
      allow update: if isAdmin() || (
        isAuth()
        && isNotBanned()
        && (
          (resource.data.patientId == request.auth.uid
            && request.resource.data.status in ['Cancelled', 'cancelled', 'Rescheduled', 'rescheduled'])
          || (resource.data.doctorId == request.auth.uid
            && request.resource.data.status in ['Approved', 'approved', 'Completed', 'completed', 'Cancelled', 'cancelled'])
        )
      );
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      allow read: if isAuth() && isNotBanned() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAuth() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isDoctor()
        && isNotBanned()
        && request.resource.data.doctorId == request.auth.uid;
      allow update: if isAdmin() || (
        isDoctor()
        && resource.data.doctorId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow read: if isAuth() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        (isDoctor() && resource.data.consentGranted == true) ||
        isAdmin()
      );
      allow create: if isAuth()
        && isNotBanned()
        && (request.resource.data.patientId == request.auth.uid
          || request.resource.data.userId == request.auth.uid
          || isAdmin());
      allow update, delete: if isAdmin() || (
        isAuth()
        && (resource.data.patientId == request.auth.uid || resource.data.userId == request.auth.uid)
      );
    }

    match /health_records/{recordId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (isDoctor() && resource.data.consentGranted == true) ||
        isAdmin()
      );
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (
        isAuth() && resource.data.userId == request.auth.uid
      );
    }

    match /payments/{paymentId} {
      allow read: if isAuth() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isPatient()
        && isNotBanned()
        && request.resource.data.patientId == request.auth.uid;
      allow update: if isAuth() && resource.data.patientId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAdmin() || (
        isAuth() && request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || (
        isAuth() && resource.data.userId == request.auth.uid
      );
    }

    match /chats/{chatId} {
      allow read, update, delete: if isAuth()
        && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /health_metrics/{metricId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (
        isAuth() && resource.data.userId == request.auth.uid
      );
    }

    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /labs/{labId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Chats and messages: only participants (and admins) may access
    match /chats/{chatId} {
      allow read: if isAuth() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuth()
        && request.resource.data.keys().hasAny(['participants'])
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAdmin() || (
        isAuth()
        && request.auth.uid in resource.data.participants
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage','updatedAt','metadata'])
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAny(['content']);
        allow update: if isAdmin() || (
          isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['content','senderId','timestamp','type'])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt','metadata'])
        );
        allow delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
