rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isValidDocument() {
      return (request.resource.contentType.matches('image/.*') ||
              request.resource.contentType == 'application/pdf') &&
             request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // ── User profile pictures ─────────────────────────────────────────────

    match /users/{userId}/profile/{fileName} {
      allow read: if true; // Public profile pictures
      allow write: if isOwner(userId) && isValidImage();
    }

    // ── Doctor documents (certificates, licenses) ─────────────────────────

    match /doctors/{doctorId}/documents/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidDocument();
    }

    // ── Medical records ───────────────────────────────────────────────────

    match /medical_records/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidDocument();
    }

    // ── Prescriptions ─────────────────────────────────────────────────────

    match /prescriptions/{prescriptionId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidDocument();
    }

    // ── Lab results ───────────────────────────────────────────────────────

    match /lab_results/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isAuthenticated() && isValidDocument();
    }

    // ── Chat attachments ──────────────────────────────────────────────────

    match /chat_attachments/{chatId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidDocument();
    }
  }
}
